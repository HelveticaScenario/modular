{
    "$schema": "https://unpkg.com/knip@6.1.1/schema.json",
    "entry": [
        "src/main/main.ts",
        "src/preload/preload.ts",
        "vite.main.config.ts",
        "vite.preload.config.ts",
        "vite.renderer.config.ts",
        "forge.config.ts",
        "scripts/**/*.{ts,mjs}",
        "src/main/dsl/GraphBuilder.ts",
        "src/main/dsl/executor.ts",
        "src/main/dsl/factories.ts",
        "src/renderer/components/monaco/definitionProvider.ts",
        "src/shared/dsl/typeDocs.ts"
    ],
    "project": ["e2e/**/*.ts"],
    "ignore": [
        "crates/modular/scripts/copy-host-binary-to-npm.mjs",
        "crates/modular/wasi-worker-browser.mjs"
    ],
    "ignoreDependencies": [
        "@modular/core",
        "@monaco-editor/react",
        "react-markdown",
        "ts-morph",
        "uuid",
        "@fontsource/anonymous-pro",
        "@fontsource/cascadia-code",
        "@fontsource/commit-mono",
        "@fontsource/fira-code",
        "@fontsource/geist-mono",
        "@fontsource/ibm-plex-mono",
        "@fontsource/inconsolata",
        "@fontsource/iosevka",
        "@fontsource/jetbrains-mono",
        "@fontsource/maple-mono",
        "@fontsource/monaspace-argon",
        "@fontsource/monaspace-krypton",
        "@fontsource/monaspace-neon",
        "@fontsource/monaspace-radon",
        "@fontsource/monaspace-xenon",
        "@fontsource/mononoki",
        "@fontsource/recursive",
        "@fontsource/roboto-mono",
        "@fontsource/source-code-pro",
        "@fontsource/victor-mono",
        "@emnapi/core",
        "@tybys/wasm-util",
        "chalk",
        "lint-staged",
        "@electron-forge/maker-flatpak",
        "@electron/notarize",
        "@electron/osx-sign",
        "playwright",
        "@electron-forge/shared-types",
        "@modular/core-android-arm64",
        "@modular/core-android-arm-eabi",
        "@modular/core-win32-x64-gnu",
        "@modular/core-win32-x64-msvc",
        "@modular/core-win32-ia32-msvc",
        "@modular/core-win32-arm64-msvc",
        "@modular/core-darwin-universal",
        "@modular/core-darwin-x64",
        "@modular/core-darwin-arm64",
        "@modular/core-freebsd-x64",
        "@modular/core-freebsd-arm64",
        "@modular/core-linux-x64-musl",
        "@modular/core-linux-x64-gnu",
        "@modular/core-linux-arm64-musl",
        "@modular/core-linux-arm64-gnu",
        "@modular/core-linux-arm-musleabihf",
        "@modular/core-linux-arm-gnueabihf",
        "@modular/core-linux-loong64-musl",
        "@modular/core-linux-loong64-gnu",
        "@modular/core-linux-riscv64-musl",
        "@modular/core-linux-riscv64-gnu",
        "@modular/core-linux-ppc64-gnu",
        "@modular/core-linux-s390x-gnu",
        "@modular/core-openharmony-arm64",
        "@modular/core-openharmony-x64",
        "@modular/core-openharmony-arm",
        "@modular/core-wasm32-wasi"
    ],
    "ignoreBinaries": ["build", "electron-rebuild"],
    "ignoreExportsUsedInFile": true,
    "rules": {
        "unresolved": "off"
    }
}
