{
    "$schema": "https://unpkg.com/knip@6.1.1/schema.json",
    "entry": [
        "src/main/main.ts",
        "src/renderer/renderer.tsx",
        "src/preload/preload.ts",
        "vite.main.config.ts",
        "vite.preload.config.ts",
        "vite.renderer.config.ts",
        "forge.config.ts",
        "vitest.config.ts",
        "playwright.config.ts",
        "scripts/**/*.{ts,mjs}"
    ],
    "project": [
        "src/**/*.{ts,tsx}",
        "crates/modular/__test__/**/*.ts",
        "e2e/**/*.ts"
    ],
    "ignoreDependencies": ["@modular/core"]
}
