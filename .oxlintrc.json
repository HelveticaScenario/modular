{
    "$schema": "https://cdn.jsdelivr.net/npm/oxlint@1.58.0/configuration_schema.json",
    "plugins": ["react", "typescript"],
    "categories": {
        "correctness": "error",
        "suspicious": "error",
        "pedantic": "warn",
        "style": "warn",
        "restriction": "warn",
        "nursery": "warn"
    },
    "env": {
        "browser": true,
        "node": true,
        "es2022": true
    }
}
